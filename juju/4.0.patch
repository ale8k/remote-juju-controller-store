 	"github.com/juju/collections/set"
@@ -214,7 +216,41 @@ func juju2xConfigDataExists() bool {
 
 // NewJujuCommand creates the "juju" super command.
 func NewJujuCommand(ctx *cmd.Context, jujuMsg string) cmd.Command {
-	return NewJujuCommandWithStore(ctx, jujuclient.NewFileClientStore(), jujucmd.DefaultLog, jujuMsg, cliHelpHint, nil, false)
+	return NewJujuCommandWithStore(ctx, clientStore(), jujucmd.DefaultLog, jujuMsg, cliHelpHint, nil, false)
+}
+
+// clientStore returns a RemoteStore if an RCS session is available,
+// otherwise falls back to the default file-backed store.
+func clientStore() jujuclient.ClientStore {
+	// First check env var for backward compatibility
+	if addr := os.Getenv("REMOTE_CONTROLLER_STORE"); addr != "" {
+		return jujuclient.NewRemoteStore(addr)
+	}
+
+	// Check for RCS session file
+	home, err := os.UserHomeDir()
+	if err != nil {
+		return jujuclient.NewFileClientStore()
+	}
+
+	sessionPath := filepath.Join(home, ".local", "share", "rcs", "session.json")
+
+	b, err := os.ReadFile(sessionPath)
+	if err != nil {
+		// No session file, use default store
+		return jujuclient.NewFileClientStore()
+	}
+
+	var session struct {
+		Token string `json:"token"`
+		Addr  string `json:"addr"`
+	}
+	if err := json.Unmarshal(b, &session); err != nil || session.Addr == "" {
+		// Invalid session or no server address, use default store
+		return jujuclient.NewFileClientStore()
+	}
+
+	return jujuclient.NewRemoteStore(session.Addr)
 }
 
 // NewJujuCommandWithStore creates the "juju" super command with the specified parameters.
