new file mode 100644
index 0000000000..8238d67173
--- /dev/null
+++ b/api/rcsjwtloginprovider.go
@@ -0,0 +1,135 @@
+// Copyright 2026 Canonical Ltd.
+// Licensed under the AGPLv3, see LICENCE file for details.
+
+package api
+
+import (
+	"context"
+	"encoding/base64"
+	"encoding/json"
+	"fmt"
+	"net/http"
+	"strings"
+
+	"github.com/juju/errors"
+
+	"github.com/ale8k/remote-juju-controller-store/pkg/client"
+	"github.com/juju/juju/api/base"
+	jujuversion "github.com/juju/juju/core/version"
+	"github.com/juju/juju/rpc/params"
+)
+
+// NewRCSJWTLoginProvider returns a LoginProvider that mints a short-lived
+// controller-login JWT from RCS and presents it directly to the controller.
+//
+// rcsServerURL is the base URL of the RCS server (e.g. "http://localhost:8484").
+// rcsSessionToken is the Bearer token from session.json.
+// controllerName is the RCS controller name used to mint the token.
+func NewRCSJWTLoginProvider(rcsServerURL, rcsSessionToken, controllerName string) LoginProvider {
+	return &rcsJWTLoginProvider{
+		rcsServerURL:    rcsServerURL,
+		rcsSessionToken: rcsSessionToken,
+		controllerName:  controllerName,
+	}
+}
+
+type rcsJWTLoginProvider struct {
+	rcsServerURL    string
+	rcsSessionToken string
+	controllerName  string
+}
+
+// Login implements LoginProvider.Login.
+// It mints a fresh JWT from RCS and submits it to the controller Admin.Login RPC.
+func (p *rcsJWTLoginProvider) Login(ctx context.Context, caller base.APICaller) (*LoginResultParams, error) {
+	jwt, err := p.mintJWT(ctx)
+	if err != nil {
+		return nil, errors.Annotate(err, "rcs jwt login provider: mint controller token")
+	}
+
+	authTag, err := jwtSubClaim(jwt)
+	if err != nil {
+		return nil, errors.Annotate(err, "rcs jwt login provider: extract sub from token")
+	}
+
+	var result params.LoginResult
+	err = caller.APICall(ctx, "Admin", 3, "", "Login", &params.LoginRequest{
+		AuthTag:       authTag,
+		Token:         jwt,
+		ClientVersion: jujuversion.Current.String(),
+	}, &result)
+	if err != nil {
+		return nil, errors.Trace(err)
+	}
+
+	return NewLoginResultParams(result)
+}
+
+// AuthHeader implements LoginProvider.AuthHeader.
+// Returns the JWT as a Bearer token for HTTP endpoints (e.g. debug-log).
+func (p *rcsJWTLoginProvider) AuthHeader() (http.Header, error) {
+	jwt, err := p.mintJWT(context.Background())
+	if err != nil {
+		return nil, errors.Annotate(err, "rcs jwt login provider: mint controller token for auth header")
+	}
+	h := make(http.Header)
+	h.Set("Authorization", "Bearer "+jwt)
+	return h, nil
+}
+
+// String implements LoginProvider.String.
+func (p *rcsJWTLoginProvider) String() string {
+	return fmt.Sprintf("RCSJWTLoginProvider(%s)", p.controllerName)
+}
+
+// mintJWT calls the RCS token endpoint and returns the base64-encoded JWT.
+func (p *rcsJWTLoginProvider) mintJWT(ctx context.Context) (string, error) {
+	rcsClient, err := client.NewClientWithResponses(
+		p.rcsServerURL,
+		client.WithRequestEditorFn(func(_ context.Context, req *http.Request) error {
+			req.Header.Set("Authorization", "Bearer "+p.rcsSessionToken)
+			return nil
+		}),
+	)
+	if err != nil {
+		return "", errors.Annotate(err, "create RCS client")
+	}
+
+	resp, err := rcsClient.MintControllerTokenWithResponse(ctx, p.controllerName)
+	if err != nil {
+		return "", errors.Annotate(err, "POST controller token")
+	}
+	if resp.StatusCode() != http.StatusOK || resp.JSON200 == nil {
+		return "", fmt.Errorf("RCS token endpoint returned %s", resp.Status())
+	}
+
+	return resp.JSON200.Token, nil
+}
+
+// jwtSubClaim decodes the JWT payload (without verifying the signature) and
+// returns the "sub" claim, which carries the Juju user tag.
+func jwtSubClaim(base64JWT string) (string, error) {
+	raw, err := base64.StdEncoding.DecodeString(base64JWT)
+	if err != nil {
+		return "", errors.Annotate(err, "base64 decode JWT")
+	}
+	parts := strings.Split(string(raw), ".")
+	if len(parts) != 3 {
+		return "", fmt.Errorf("malformed JWT: expected 3 parts, got %d", len(parts))
+	}
+	// JWT uses base64url (no padding); use RawURLEncoding.
+	payload, err := base64.RawURLEncoding.DecodeString(parts[1])
+	if err != nil {
+		return "", errors.Annotate(err, "base64url decode JWT payload")
+	}
+	var claims struct {
+		Sub string `json:"sub"`
+	}
+	if err := json.Unmarshal(payload, &claims); err != nil {
+		return "", errors.Annotate(err, "unmarshal JWT claims")
+	}
+	if claims.Sub == "" {
+		return "", fmt.Errorf("JWT missing sub claim")
+	}
+	return claims.Sub, nil
+}
