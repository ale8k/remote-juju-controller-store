+// RemoteStore implements ClientStore by communicating with a
+// remote-controller-store HTTP server. Use NewRemoteStore to create one.
+type RemoteStore struct {
+	api     client.ClientWithResponsesInterface
+	baseURL string
+	initErr error
+}
+
+// NewRemoteStore returns a RemoteStore that proxies all ClientStore calls to
+// the server at addr (host:port, no scheme).
+func NewRemoteStore(addr string) *RemoteStore {
+	baseURL := addr
+	if !strings.Contains(baseURL, "://") {
+		baseURL = "http://" + baseURL
+	}
+
+	api, err := client.NewClientWithResponses(
+		baseURL,
+		client.WithRequestEditorFn(addAuthHeader),
+	)
+	if err != nil {
+		return &RemoteStore{initErr: errors.Trace(err)}
+	}
+
+	return &RemoteStore{api: api, baseURL: baseURL}
+}
+
+func (s *RemoteStore) ready() error {
+	if s.initErr != nil {
+		return errors.Trace(s.initErr)
+	}
+	if s.api == nil {
+		return errors.New("remote store client is not initialized")
+	}
+	return nil
+}
+
+func addAuthHeader(_ context.Context, req *http.Request) error {
+	tok, err := loadSessionToken()
+	if err != nil {
+		return err
+	}
+	req.Header.Set("Authorization", "Bearer "+tok)
+	return nil
+}
+
+type rcsSession struct {
+	Token string `json:"token"`
+	Addr  string `json:"addr"`
+}
+
+func loadSessionToken() (string, error) {
+	if tok := strings.TrimSpace(os.Getenv("RCS_SESSION_TOKEN")); tok != "" {
+		return tok, nil
+	}
+
+	sessionPath := strings.TrimSpace(os.Getenv("RCS_SESSION_PATH"))
+	if sessionPath == "" {
+		home, err := os.UserHomeDir()
+		if err != nil {
+			return "", errors.Trace(err)
+		}
+		sessionPath = filepath.Join(home, ".local", "share", "rcs", "session.json")
+	}
+
+	b, err := os.ReadFile(sessionPath)
+	if err != nil {
+		return "", errors.Annotatef(err, "read RCS session file %q", sessionPath)
+	}
+
+	var s rcsSession
+	if err := json.Unmarshal(b, &s); err != nil {
+		return "", errors.Annotatef(err, "parse RCS session file %q", sessionPath)
+	}
+	if strings.TrimSpace(s.Token) == "" {
+		return "", fmt.Errorf("RCS session file %q does not contain a token", sessionPath)
+	}
+	return s.Token, nil
+}
+
+func checkStatus(statusCode int, status string, body []byte) error {
+	if statusCode >= 200 && statusCode < 300 {
+		return nil
+	}
+	msg := strings.TrimSpace(string(body))
+	switch statusCode {
+	case http.StatusNotFound:
+		return errors.NotFoundf("%s", msg)
+	case http.StatusConflict:
+		return errors.AlreadyExistsf("%s", msg)
+	}
+	return fmt.Errorf("remote store: %s: %s", status, msg)
+}
+
+func marshalBody(v any) (*bytes.Reader, error) {
+	b, err := json.Marshal(v)
+	if err != nil {
+		return nil, errors.Trace(err)
+	}
+	return bytes.NewReader(b), nil
+}
