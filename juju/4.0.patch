+// -- ModelUpdater -------------------------------------------------------------
+
+// modelURL returns the URL for individual model operations using the
+// /by-name?model= pattern, which avoids Gin path-routing conflicts caused by
+// slash characters in qualified model names (e.g. "admin/default").
+func (s *RemoteStore) modelURL(controllerName, modelName string) (string, error) {
+	base, err := url.Parse(s.baseURL)
+	if err != nil {
+		return "", errors.Trace(err)
+	}
+	base.Path = fmt.Sprintf("/controllers/%s/models/by-name", controllerName)
+	q := base.Query()
+	q.Set("model", modelName)
+	base.RawQuery = q.Encode()
+	return base.String(), nil
+}
+
+// doModelRequest performs a direct HTTP request for an individual model
+// operation so that qualified model names (containing "/") are sent as a
+// query parameter rather than a path segment.
+func (s *RemoteStore) doModelRequest(method, rawURL string, body *bytes.Reader) (int, []byte, error) {
+	var bodyReader io.Reader
+	if body != nil {
+		bodyReader = body
+	}
+	req, err := http.NewRequestWithContext(context.Background(), method, rawURL, bodyReader)
+	if err != nil {
+		return 0, nil, errors.Trace(err)
+	}
+	if body != nil {
+		req.Header.Set("Content-Type", "application/json")
+	}
+	if err := addAuthHeader(context.Background(), req); err != nil {
+		return 0, nil, errors.Trace(err)
+	}
+	resp, err := http.DefaultClient.Do(req)
+	if err != nil {
+		return 0, nil, errors.Trace(err)
+	}
+	defer resp.Body.Close() //nolint:errcheck
+	var buf bytes.Buffer
+	_, _ = buf.ReadFrom(resp.Body)
+	return resp.StatusCode, buf.Bytes(), nil
+}
