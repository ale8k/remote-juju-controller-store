@@ -821,3 +829,41 @@ func InnerCommand(c cmd.Command) cmd.Command {
 		c = c1.inner()
 	}
 }
+
+// rcsSessionData holds the token and server URL loaded from the RCS session file.
+type rcsSessionData struct {
+	token  string
+	server string
+}
+
+// loadRCSSessionFile reads ~/.local/share/rcs/session.json and returns the
+// session data. Returns false if the file is absent or invalid.
+func loadRCSSessionFile() (rcsSessionData, bool) {
+	if addr := os.Getenv("REMOTE_CONTROLLER_STORE"); addr != "" {
+		token := os.Getenv("RCS_SESSION_TOKEN")
+		if token != "" {
+			return rcsSessionData{token: token, server: addr}, true
+		}
+	}
+
+	home, err := os.UserHomeDir()
+	if err != nil {
+		return rcsSessionData{}, false
+	}
+
+	sessionPath := filepath.Join(home, ".local", "share", "rcs", "session.json")
+	b, err := os.ReadFile(sessionPath)
+	if err != nil {
+		return rcsSessionData{}, false
+	}
+
+	var s struct {
+		Token string `json:"token"`
+		Addr  string `json:"addr"`
+	}
+	if err := json.Unmarshal(b, &s); err != nil || s.Token == "" || s.Addr == "" {
+		return rcsSessionData{}, false
+	}
+
+	return rcsSessionData{token: s.Token, server: s.Addr}, true
+}
