+	}
+	if err := ValidateControllerName(controller); err != nil {
+		return err
+	}
+	body, err := marshalBody(cfg)
+	if err != nil {
+		return err
+	}
+	resp, err := s.api.UpdateBootstrapConfigWithBodyWithResponse(context.Background(), controller, "application/json", body)
+	if err != nil {
+		return errors.Trace(err)
+	}
+	return checkStatus(resp.StatusCode(), resp.Status(), resp.Body)
+}
+
+// -- BootstrapConfigGetter ----------------------------------------------------
+
+// BootstrapConfigForController implements BootstrapConfigGetter.
+func (s *RemoteStore) BootstrapConfigForController(controllerName string) (*BootstrapConfig, error) {
+	if err := s.ready(); err != nil {
+		return nil, err
+	}
+	resp, err := s.api.BootstrapConfigWithResponse(context.Background(), controllerName)
+	if err != nil {
+		return nil, errors.Trace(err)
+	}
+	if err := checkStatus(resp.StatusCode(), resp.Status(), resp.Body); err != nil {
+		return nil, err
+	}
+
+	var cfg BootstrapConfig
+	if err := json.Unmarshal(resp.Body, &cfg); err != nil {
+		return nil, errors.Trace(err)
+	}
+	return &cfg, nil
+}
+
+// -- CookieStore --------------------------------------------------------------
+
+// CookieJar implements CookieStore. It fetches any existing cookies for the
+// controller from the server and returns an in-memory jar that persists back
+// via Save().
+func (s *RemoteStore) CookieJar(controllerName string) (CookieJar, error) {
+	jar := &remoteCookieJar{
+		store:      s,
+		controller: controllerName,
+		entries:    make(map[string][]*http.Cookie),
+	}
+
+	if err := s.ready(); err != nil {
+		return jar, nil
+	}
+
+	resp, err := s.api.GetCookiesWithResponse(context.Background(), controllerName)
+	if err != nil {
+		return nil, errors.Trace(err)
+	}
+	if err := checkStatus(resp.StatusCode(), resp.Status(), resp.Body); err != nil {
+		// Best effort: preserve previous behavior and return empty in-memory jar.
+		return jar, nil
+	}
+
+	var raw []cookieEntry
+	if err := json.Unmarshal(resp.Body, &raw); err != nil {
+		return nil, errors.Trace(err)
+	}
+	for _, e := range raw {
+		jar.entries[e.URL] = append(jar.entries[e.URL], e.toCookie())
+	}
+	return jar, nil
+}
+
+// cookieEntry is the JSON representation of a single cookie stored on the server.
+type cookieEntry struct {
+	URL      string `json:"url"`
+	Name     string `json:"name"`
+	Value    string `json:"value"`
+	Path     string `json:"path,omitempty"`
+	Domain   string `json:"domain,omitempty"`
+	Secure   bool   `json:"secure,omitempty"`
+	HttpOnly bool   `json:"httpOnly,omitempty"`
+}
+
+func (e cookieEntry) toCookie() *http.Cookie {
+	return &http.Cookie{
+		Name:     e.Name,
+		Value:    e.Value,
+		Path:     e.Path,
+		Domain:   e.Domain,
+		Secure:   e.Secure,
+		HttpOnly: e.HttpOnly,
+	}
+}
+
+func cookieEntryFrom(rawURL string, c *http.Cookie) cookieEntry {
+	return cookieEntry{
+		URL:      rawURL,
+		Name:     c.Name,
+		Value:    c.Value,
+		Path:     c.Path,
+		Domain:   c.Domain,
+		Secure:   c.Secure,
+		HttpOnly: c.HttpOnly,
+	}
+}
+
+// remoteCookieJar implements CookieJar backed by the remote server.
+type remoteCookieJar struct {
+	store      *RemoteStore
+	controller string
+	mu         sync.Mutex
+	// entries maps URL string -> cookies for that URL.
+	entries map[string][]*http.Cookie
+}
+
+// Cookies implements http.CookieJar.
+func (j *remoteCookieJar) Cookies(u *url.URL) []*http.Cookie {
+	j.mu.Lock()
+	defer j.mu.Unlock()
+	return j.entries[u.String()]
+}
+
+// SetCookies implements http.CookieJar.
+func (j *remoteCookieJar) SetCookies(u *url.URL, cookies []*http.Cookie) {
+	j.mu.Lock()
+	defer j.mu.Unlock()
+	key := u.String()
+
+	// Merge: replace by name, add new.
+	existing := j.entries[key]
+	for _, incoming := range cookies {
+		found := false
+		for i, e := range existing {
+			if e.Name == incoming.Name {
+				existing[i] = incoming
+				found = true
+				break
+			}
+		}
+		if !found {
+			existing = append(existing, incoming)
+		}
+	}
+	j.entries[key] = existing
+}
+
+// RemoveAll implements CookieJar. Clears in-memory cookies and removes them
+// from the server.
+func (j *remoteCookieJar) RemoveAll() {
+	j.mu.Lock()
+	j.entries = make(map[string][]*http.Cookie)
+	j.mu.Unlock()
+
+	if err := j.store.ready(); err != nil {
+		return
+	}
+	resp, err := j.store.api.RemoveAllCookiesWithResponse(context.Background(), j.controller)
+	if err != nil {
+		return
+	}
+	_ = checkStatus(resp.StatusCode(), resp.Status(), resp.Body)
+}
+
+// Save implements CookieJar. Persists in-memory cookies to the server.
+func (j *remoteCookieJar) Save() error {
+	if err := j.store.ready(); err != nil {
+		return err
+	}
+
+	j.mu.Lock()
+	var flat []cookieEntry
+	for rawURL, cookies := range j.entries {
+		for _, c := range cookies {
+			flat = append(flat, cookieEntryFrom(rawURL, c))
+		}
+	}
+	j.mu.Unlock()
+
+	body, err := marshalBody(flat)
+	if err != nil {
+		return err
+	}
+	resp, err := j.store.api.SaveCookiesWithBodyWithResponse(context.Background(), j.controller, "application/json", body)
+	if err != nil {
+		return errors.Trace(err)
+	}
+	return checkStatus(resp.StatusCode(), resp.Status(), resp.Body)
+}
