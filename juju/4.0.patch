+// UpdateModel implements ModelUpdater.
+func (s *RemoteStore) UpdateModel(controllerName, modelName string, details ModelDetails) error {
+	if err := s.ready(); err != nil {
+		return err
+	}
+	if err := ValidateControllerName(controllerName); err != nil {
+		return err
+	}
+	if err := ValidateModel(modelName, details); err != nil {
+		return err
+	}
+	body, err := marshalBody(details)
+	if err != nil {
+		return err
+	}
+	rawURL, err := s.modelURL(controllerName, modelName)
+	if err != nil {
+		return err
+	}
+	code, respBody, err := s.doModelRequest(http.MethodPut, rawURL, body)
+	if err != nil {
+		return errors.Trace(err)
+	}
+	return checkStatus(code, http.StatusText(code), respBody)
+}
